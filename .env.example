# ================================
# CampusConnect Environment Variables
# ================================
# Bu dosyayı .env olarak kopyalayın ve değerleri güncelleyin.
# cp .env.example .env

# ---- PostgreSQL ----
POSTGRES_USER=campusconnect
POSTGRES_PASSWORD=campusconnect_secret
POSTGRES_DB=campusconnect

# ---- NestJS ----
JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=1d
WEBHOOK_SECRET=webhook_shared_secret_key
GO_SERVICE_URL=http://go-service:8080

# ---- Go Service ----
API_KEY=campusconnect_api_key_change_in_production
RATE_LIMIT_RPM=60
