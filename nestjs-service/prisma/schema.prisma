// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// User Modeli
// =====================================================
model User {
  id         String   @id @default(uuid()) @db.Uuid
  email      String   @unique @db.VarChar(255)
  password   String   @db.VarChar(255)
  firstName  String   @map("first_name") @db.VarChar(100)
  lastName   String   @map("last_name") @db.VarChar(100)
  university String?  @db.VarChar(255)
  department String?  @db.VarChar(255)
  role       String   @default("user") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // İlişkiler
  organizedEvents Event[]             @relation("OrganizerEvents")
  participations  EventParticipant[]

  @@map("users")
}

// =====================================================
// Event Modeli
// =====================================================
model Event {
  id              String   @id @default(uuid()) @db.Uuid
  title           String   @db.VarChar(255)
  description     String?  @db.Text
  category        String   @db.VarChar(100)
  city            String   @db.VarChar(100)
  location        String?  @db.VarChar(255)
  eventDate       DateTime @map("event_date") @db.Timestamptz
  maxParticipants Int      @default(0) @map("max_participants")
  imageUrl        String?  @map("image_url") @db.VarChar(500)
  organizerId     String   @map("organizer_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // İlişkiler
  organizer    User               @relation("OrganizerEvents", fields: [organizerId], references: [id], onDelete: Cascade)
  participants EventParticipant[]

  @@index([category])
  @@index([city])
  @@index([eventDate])
  @@index([organizerId])
  @@map("events")
}

// =====================================================
// EventParticipant Modeli (Many-to-Many)
// =====================================================
model EventParticipant {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  eventId  String   @map("event_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz

  // İlişkiler
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
  @@map("event_participants")
}

// =====================================================
// WebhookLog Modeli (Go servisi de bu tabloya yazar)
// =====================================================
model WebhookLog {
  id         String   @id @default(uuid()) @db.Uuid
  eventId    String?  @map("event_id") @db.Uuid
  eventTitle String?  @map("event_title") @db.VarChar(255)
  payload    Json?
  signature  String?  @db.VarChar(255)
  status     String   @default("received") @db.VarChar(50)
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([eventId])
  @@index([createdAt])
  @@map("webhook_logs")
}
